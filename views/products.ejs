<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("./includes/metadata.ejs") %>
    <link rel="stylesheet" href="/css/products.css" />
  </head>
  <body>
    <%- include("./includes/header.ejs") %>

    <div class="products-header">
      <div class="container">
        <h1 class="products-header__title">Our Products</h1>
        <p class="products-header__subtitle">Discover our amazing collection of quality products</p>
      </div>
    </div>

    <main class="content-wrapper">
      <div class="container">
        <% if (products && products.length > 0) { %>
          <div class="products-grid">
            <% for( let product of products ) { %>
              <div class="product-card">
                <div class="product-card__image">
                  📱
                </div>
                <div class="product-card__content">
                  <h3 class="product-card__name"><%= product.productName %></h3>
                  
                  <div class="product-details">
                    <div class="product-detail-row">
                      <span class="product-detail-label">Price</span>
                      <span class="product-detail-value product-price">$<%= product.productPrice %></span>
                    </div>
                    <div class="product-detail-row">
                      <span class="product-detail-label">In Stock</span>
                      <span class="product-quantity">
                        <span class="quantity-badge <%= product.productQuantity > 20 ? 'in-stock' : product.productQuantity > 5 ? 'low-stock' : 'out-of-stock' %>">
                          <%= product.productQuantity %> units
                        </span>
                      </span>
                    </div>
                  </div>

                  <div class="product-card__actions">
                    <button class="product-card__edit" onclick="alert('Edit functionality coming soon!')">Edit</button>
                    <button class="product-card__delete" onclick="alert('Delete functionality coming soon!')">Delete</button>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state__icon">📦</div>
            <h2 class="empty-state__title">No Products Found</h2>
            <p class="empty-state__message">Start by adding your first product to the store</p>
            <a href="/admin/add-product" class="btn btn-primary empty-state__action">Add First Product</a>
          </div>
        <% } %>
      </div>
    </main>
  </body>
</html>
