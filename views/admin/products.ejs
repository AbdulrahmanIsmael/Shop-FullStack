<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../includes/metadata.ejs") %>
    <link rel="stylesheet" href="/css/products.css" />
  </head>
  <body>
    <%- include("../includes/header.ejs") %>

    <div class="products-header">
      <div class="container">
        <h1 class="products-header__title">All Products</h1>
      </div>
    </div>

    <main class="content-wrapper">
      <div class="container">
        <% if (products && products.length > 0) { %>
          <div class="products-grid">
            <% for( let product of products ) { %>
              <div class="product-card">
                <% if(product.productImage) { %>
                  <img src="<%=product.productImage%>" alt="<%= product.productName %> image" class="product-card__image"/>
                <% } else { %>
                <div class="product-card__image">
                  📱
                </div>
                <% } %>
                <div class="product-card__content">
                  <h3 class="product-card__name"><%= product.productName %></h3>
                  <p class="product-card__desc"><%= product.productDesc %></p>
                  
                  <div class="product-details">
                    <div class="product-detail-row">
                      <span class="product-detail-label">Price</span>
                      <span class="product-detail-value product-price">$<%= product.productPrice %></span>
                    </div>
                    <div class="product-detail-row">
                      <span class="product-detail-label">In Stock</span>
                      <span class="product-quantity">
                        <span class="badge <%= product.productQuantity > 20 ? 'in-stock' : product.productQuantity > 5 ? 'low-stock' : 'out-of-stock' %>">
                          <span class="status-dot"></span> <%= product.productQuantity %> units
                        </span>
                      </span>
                    </div>
                  </div>

                  <div class="product-card__actions">
                    <a href="/admin/edit-product/<%= product.productId %>?edit=true" class="product-card__edit">Edit</a>
                    <!-- ! Change to submit button when adding deleting admin feature -->
                    <form action="/admin/delete-product/<%= product.productId %>" method="POST">
                      <button type="submit" class="product-card__delete">Delete</button>
                    </form>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-state__icon">📦</div>
            <h2 class="empty-state__title">No Products Found</h2>
            <p class="empty-state__message">Start by adding your first product to the store</p>
            <a href="/admin/add-product" class="btn btn-primary empty-state__action">Add First Product</a>
          </div>
        <% } %>
      </div>
    </main>
    <%- include("../includes/footer.ejs") %>
  </body>
</html>
