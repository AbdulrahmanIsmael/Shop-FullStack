<div class="logo">
  <svg
    class="logo__icon"
    viewBox="0 0 100 100"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Shopping bag -->
    <rect
      x="30"
      y="35"
      width="40"
      height="45"
      rx="4"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
    />
    <!-- Handle -->
    <path
      d="M 40 35 Q 40 15 50 15 Q 60 15 60 35"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
    />
    <!-- Decorative elements -->
    <circle cx="50" cy="55" r="3" fill="currentColor" />
    <circle cx="40" cy="65" r="2" fill="currentColor" />
    <circle cx="60" cy="65" r="2" fill="currentColor" />
  </svg>
  <span class="logo__text">ShopHub</span>
</div>
