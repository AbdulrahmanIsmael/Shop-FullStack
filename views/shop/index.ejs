<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../includes/metadata.ejs") %>
    <link rel="stylesheet" href="/css/products.css" />
  </head>
  <body>
    <%- include("../includes/header.ejs") %>

    <div class="products-header hero-header">
      <div class="container">
        <h1 class="products-header__title">Welcome To Our Shop</h1>
        <p class="products-header__subtitle">Discover our amazing collection of quality products and join our clients family</p>
        <a href="#featured" class="btn btn-primary hero-btn">Shop Now</a>
      </div>
    </div>

    <!-- Features Section -->
    <section class="features-section bg-light">
      <div class="container">
        <div class="features-grid">
          <div class="feature-item">
            <div class="feature-icon">🚀</div>
            <h3>Fast Delivery</h3>
            <p>Get your products delivered to your doorsteps quickly.</p>
          </div>
          <div class="feature-item">
            <div class="feature-icon">🛡️</div>
            <h3>Secure Payment</h3>
            <p>100% secure payment processing for your peace of mind.</p>
          </div>
          <div class="feature-item">
            <div class="feature-icon">⭐</div>
            <h3>Top Quality</h3>
            <p>We provide only the best quality products for our customers.</p>
          </div>
          <div class="feature-item">
            <div class="feature-icon">📞</div>
            <h3>24/7 Support</h3>
            <p>Our team is available round the clock to help you.</p>
          </div>
        </div>
      </div>
    </section>

    <main class="content-wrapper">
      
      <!-- Featured Products Section -->
      <section id="featured" class="featured-products-section">
        <div class="container">
          <div class="section-title">
            <h2>Featured Products</h2>
            <p>Check out some of our best sellers</p>
          </div>

          <% if (products && products.length > 0) { %>
            <div class="products-grid">
              <% for( let product of products.slice(0, 10) ) { %>
                <div class="product-card">
                  <% if(product.productImage) { %>
                    <img src="<%=product.productImage%>" alt="<%= product.productName %> image" class="product-card__image"/>
                  <% } else { %>
                  <div class="product-card__image">
                    📱
                  </div>
                  <% } %>
                  <!-- Add To Cart Button -->
                  <!-- ! Change type button to submit later when adding the cart feature -->
                  <form action="/cart" method="POST" class="add-to-cart-btn">
                    <button type="submit" aria-label="Add to Cart">🛒</button>
                    <input type="hidden" name="productId" value="<%= product.productId %>">
                  </form>

                  <div class="product-card__content">
                    <h3 class="product-card__name"><%= product.productName %></h3>
                    <p class="product-card__desc"><%= product.productDesc %></p>
                    
                    <div class="product-details">
                      <div class="product-detail-row">
                        <span class="product-detail-label">Price</span>
                        <span class="product-detail-value product-price">$<%= product.productPrice %></span>
                      </div>
                      <div class="product-detail-row">
                        <span class="product-detail-label">In Stock</span>
                        <span class="product-quantity">
                          <span class="badge <%= product.productQuantity > 20 ? 'in-stock' : product.productQuantity > 5 ? 'low-stock' : 'out-of-stock' %>">
                            <span class="status-dot"></span> <%= product.productQuantity %> units
                          </span>
                        </span>
                      </div>

                      <a href="/products/<%= product.productId %>" class="product-details-btn">Details</a>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-state__icon">📦</div>
              <h2 class="empty-state__title">No Products Found</h2>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <!-- Newsletter Section -->
    <section class="newsletter-section">
      <div class="container newsletter-container">
        <div class="newsletter-content">
          <h2>Subscribe to our Newsletter</h2>
          <p>Get the latest updates on new products and upcoming sales.</p>
        </div>
        <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Thank you for subscribing! This functionality will be fully implemented soon.');">
          <input type="email" placeholder="Enter your email address" required />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
      </div>
    </section>

    <%- include("../includes/footer.ejs") %>
  </body>
</html>
